# Headscale Fabric — sensitive configuration template
# Copy to .env and fill in real values:  cp .env.example .env

# Control plane server
HEADSCALE_SERVER_HOST=
HEADSCALE_SERVER_USER=root
HEADSCALE_SERVER_PASS=

# Domain names
HEADSCALE_DOMAIN=
TAILNET_SUFFIX=

# Per-node tailnet hostnames
UBUNTU_MASTER_HOST=
UBUNTU_1_HOST=
MAC_1_HOST=
WIN_1_HOST=

# Staging server (optional, for deploy tests)
STAGING_SERVER_HOST=
STAGING_SERVER_USER=ubuntu
STAGING_SERVER_PASS=
